{
  "name": "kevinellen.com",
  "version": "1.0.0",
  "private": true,
  "description": "Personal portfolio website built on Cloudflare Workers, Terraform, KV, and Images.",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "type-check:content": "tsc --noEmit -p packages/content-pipeline/tsconfig.json",
    "type-check:all": "npm run type-check && npm run type-check:content",
    "build": "node scripts/build.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "format:tf": "terraform fmt -recursive .",
    "format:tf:check": "terraform fmt -check -recursive .",
    "test": "jest",
    "dev": "wrangler types && wrangler dev --remote",
    "cf-typegen": "wrangler types && prettier worker-configuration.d.ts --write",
    "build:styles": "sass src/styles/main.scss .build/generated/styles.css --no-source-map",
    "watch:styles": "sass --watch src/styles/main.scss:.build/generated/styles.css --no-source-map",
    "lint:styles": "stylelint \"src/styles/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/styles/**/*.scss\" --fix",
    "styles:watch": "sass --watch src/styles/main.scss:.build/generated/styles.css",
    "prepare": "husky",
    "content": "tsx packages/content-pipeline/src/cli/content.cli.ts"
  },
  "keywords": [],
  "author": "Kevin Ellen",
  "license": "UNLICENSED",
  "packageManager": "npm@11.11.0",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/dotenv": "^6.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "esbuild": "^0.27.4",
    "eslint": "10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "sass": "1.98.0",
    "schema-dts": "^1.1.5",
    "stylelint": "17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "dotenv": "^17.4.0",
    "exifr": "^7.1.3",
    "sharp": "^0.34.5"
  }
}
