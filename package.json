{
  "name": "kevinellen.com",
  "version": "1.0.0",
  "private": true,
  "description": "Personal portfolio website built on Cloudflare Workers, Terraform, KV, and Images.",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "node scripts/build.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "jest --verbose",
    "dev": "wrangler types && wrangler dev",
    "cf-typegen": "wrangler types && prettier worker-configuration.d.ts --write",
    "build:styles": "sass src/styles/main.scss .build/generated/styles.css --no-source-map",
    "watch:styles": "sass --watch src/styles/main.scss:.build/generated/styles.css --no-source-map",
    "lint:styles": "stylelint \"src/styles/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/styles/**/*.scss\" --fix",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Kevin Ellen",
  "license": "UNLICENSED",
  "packageManager": "npm@11.11.0",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "^30.0.0",
    "esbuild": "^0.27.4",
    "eslint": "10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "sass": "1.98.0",
    "schema-dts": "^1.1.5",
    "stylelint": "17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0",
    "wrangler": "^4.80.0"
  }
}
