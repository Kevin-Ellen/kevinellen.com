{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["./worker-configuration.d.ts", "jest"],
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@shared-types/*": ["./shared-types/*"],
      "@request/*": ["./src/request/*"],
      "@app-state/*": ["./src/app-state/*"],
      "@app-context/*": ["./src/app-context/*"],
      "@app-render-context/*": ["./src/app-render-context/*"],
      "@rendering/*": ["./src/rendering/*"],

      "@utils/*": ["./src/utils/*"],
      "@pages/*": ["./src/pages/*"],
      "@tests/*": ["./tests/*"]

      // "@shared-types/*": ["./packages/shared-types/src/*"],
      // "@content-pipeline/*": ["./packages/content-pipeline/src/*"],
      // "@app/*": ["./src/app/*"]
    }
  },
  "include": [
    "src",
    "tests",
    "worker-configuration.d.ts",
    // "packages/shared-types/src",
    // "packages/shared-types/src/uploads",
    "shared-types/",
    "jest.config.ts"
  ],
  "exclude": ["__OLD"]
}
