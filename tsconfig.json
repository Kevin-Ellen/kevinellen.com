{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["./worker-configuration.d.ts", "jest"],
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@request/*": ["./src/app/request/*"],
      "@config/*": ["./src/app/config/*"],
      "@utils/*": ["./src/utils/*"],
      "@tests/*": ["./tests/*"],
      "@shared-types/*": ["./packages/shared-types/src/*"],
      "@content-pipeline/*": ["./packages/content-pipeline/src/*"],
      "@app/*": ["./src/app/*"]
    }
  },
  "include": [
    "src",
    "tests",
    "worker-configuration.d.ts",
    "packages/shared-types/src",
    "packages/shared-types/src/uploads"
  ],
  "exclude": ["__OLD"]
}
