{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["./worker-configuration.d.ts", "jest"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "allowJs": false,
    "checkJs": false,

    "noEmit": true,
    "isolatedModules": true,

    "verbatimModuleSyntax": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "esModuleInterop": true,

    "paths": {
      //   "@generated/*": [".build/generated/*"],
      //   "@system/*": ["src/system/*"],
      //   "@resources/*": ["src/resources/*"],
      //   "@types-src/*": ["src/types/*"],
      "@utils/*": ["./src/utils/*"],
      "@config/*": ["./src/config/*"],
      "@app/*": ["./src/app/*"],
      "@tests/*": ["./tests/*"],
      "@src/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "worker-configuration.d.ts",
    "src/app/assets/scripts/menuCondense.inline.script.js"
  ],
  "exclude": ["dist", "coverage", "node_modules", "src/xxx___app"]
}
